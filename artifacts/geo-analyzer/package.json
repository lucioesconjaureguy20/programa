{
  "name": "@workspace/geo-analyzer",
  "version": "1.0.0",
  "description": "GeoGuessr screen analyzer with OpenAI Vision",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite dev",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.9.3",
    "vite": "^5.4.19"
  },
  "build": {
    "appId": "com.geoguessr.analyzer",
    "productName": "GeoAnalyzer",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
